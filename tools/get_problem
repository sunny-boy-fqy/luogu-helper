#!/bin/bash
# Get problem description from Luogu
# Usage: ./get_problem

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if fetch_problem executable exists
FETCH_EXE="$SCRIPT_DIR/fetch_problem"
if [ ! -f "$FETCH_EXE" ]; then
    FETCH_EXE="$SCRIPT_DIR/../tools/fetch_problem"
fi
if [ ! -f "$FETCH_EXE" ]; then
    echo "Error: fetch_problem executable not found!"
    echo "Searched in:"
    echo "  - $SCRIPT_DIR/fetch_problem"
    echo "  - $SCRIPT_DIR/../tools/fetch_problem"
    echo "Please ensure you downloaded the complete release package."
    exit 1
fi

echo "Using: $FETCH_EXE"

# Get problem ID from current directory name
PROB_ID=$(basename "$(pwd)")

echo "Fetching problem $PROB_ID..."
"$FETCH_EXE" problem "$PROB_ID" --target_dir .

if [ $? -eq 0 ]; then
    echo "Successfully saved problem.md"
else
    echo "Failed to fetch problem description"
    exit 1
fi
