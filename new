#!/bin/bash
# OI Problem setup script for Linux/macOS
# Usage: ./new <PROBLEM_ID>
# Example: ./new P1001, ./new AT_abc001_A

if [ $# -eq 0 ]; then
    echo "Usage: ./new <PROBLEM_ID>"
    echo "Example: ./new P1001, ./new AT_abc001_A"
    exit 1
fi

TARGET="$1"
PROB_ID="$TARGET"

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STD_DIR="$SCRIPT_DIR/std"

echo "Detected problem ID: $TARGET"

if [ -d "$SCRIPT_DIR/$TARGET" ]; then
    echo "Error: Directory $TARGET already exists."
    exit 1
fi

if [ ! -d "$STD_DIR" ]; then
    echo "Error: std directory not found at $STD_DIR"
    exit 1
fi

# Create target directory
mkdir -p "$SCRIPT_DIR/$TARGET"
cp -r "$STD_DIR"/* "$SCRIPT_DIR/$TARGET/"

# Check if fetch_problem executable exists in tools directory
FETCH_EXE="$SCRIPT_DIR/tools/fetch_problem"
if [ ! -f "$FETCH_EXE" ]; then
    FETCH_EXE="$SCRIPT_DIR/fetch_problem"
fi
if [ ! -f "$FETCH_EXE" ]; then
    echo "Error: fetch_problem executable not found!"
    echo "Searched in:"
    echo "  - $SCRIPT_DIR/tools/fetch_problem"
    echo "  - $SCRIPT_DIR/fetch_problem"
    echo "Please ensure you downloaded the complete release package."
    exit 1
fi

echo "Using: $FETCH_EXE"

echo "Fetching samples from Luogu..."
"$FETCH_EXE" samples "$TARGET" --target_dir "$SCRIPT_DIR/$TARGET"

if [ $? -eq 0 ]; then
    echo "Successfully set up $PROB_ID"
    echo "Please run: cd \"$SCRIPT_DIR/$TARGET\""
else
    echo "Failed to fetch samples, but directory created."
    echo "You may need to configure LUOGU_COOKIE and _uid for private problems."
    echo "Run './config_cookie' to set up your cookie and uid."
fi